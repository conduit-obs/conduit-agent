; Conduit Windows default environment file (M6.C).
;
; install.ps1 writes a starter copy of this file to
; %PROGRAMDATA%\Conduit\conduit.env on first install. Operators fill in
; HONEYCOMB_API_KEY before starting the service; the service start
; command pre-loads this file into the conduit service's environment via
; the registry value
; HKLM\SYSTEM\CurrentControlSet\Services\conduit\Environment.
;
; Format: one KEY=VALUE per line. No quotes around values; no trailing
; whitespace; lines starting with `;` or `#` are comments. The MSI
; install does not touch this file on upgrade (NeverOverwrite="yes").
;
; If you change values here, restart the service:
;   Restart-Service conduit

HONEYCOMB_API_KEY=replace-with-your-honeycomb-ingest-key
CONDUIT_SERVICE_NAME=conduit-windows
CONDUIT_DEPLOYMENT_ENVIRONMENT=production
