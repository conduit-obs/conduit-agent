# Conduit environment file. Read by the systemd unit
# (EnvironmentFile=/etc/conduit/conduit.env). Edit this file to wire
# Conduit to your Honeycomb tenant, then:
#
#   sudo systemctl restart conduit
#
# Permissions on this file are 0640 root:conduit so the api key isn't
# world-readable.

# REQUIRED. Honeycomb ingest key. Find or rotate at:
#   https://ui.honeycomb.io/<team>/environments/<env>/api_keys
HONEYCOMB_API_KEY=

# REQUIRED. service.name on every emitted signal. A short, stable name for
# the workload running on this host (e.g. "edge-gateway", "checkout-api").
CONDUIT_SERVICE_NAME=

# OPTIONAL. deployment.environment on every emitted signal. Common values:
# "production", "staging", "development". Defaults to "production".
CONDUIT_DEPLOYMENT_ENVIRONMENT=production
