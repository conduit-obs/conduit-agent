# Go module cache (in case anyone vendors locally)
vendor/

# OBI local-only build path (resolves ADR-0020's "Open question: build pipeline"
# for the local case; the public release pipeline does not link OBI). Cloned
# and codegen'd by `make obi-vendor` from upstream go.opentelemetry.io/obi at
# the pinned tag. Not committed because (a) the OBI checkout is multi-MB of
# generated eBPF C and Go bindings, and (b) the public release does not depend
# on it. See tools/local-k8s/README.md.
third_party/obi/

# IDE / editor scratch
.idea/
.vscode/
.cursor/
.zed/
*.swp
*.swo
*.bak
*.orig
*~

# OS
.DS_Store
Thumbs.db

# Local env / secrets
.env
.env.local

# Local-only test configs (kept out of OSS repo to avoid accidental key leaks)
prod-conduit.yaml

# Internal planning materials — kept on the contributor's local checkout but
# not published to the OSS repo. Public-facing planning lives in GitHub
# Issues / a project board.
/conduit-agent-plan/
