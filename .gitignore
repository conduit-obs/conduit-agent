# Go module cache (in case anyone vendors locally)
vendor/

# OBI local-only build path (ADR-0020 sub-decision 1: every Linux conduit
# binary links OBI in). `make obi-vendor` clones upstream go.opentelemetry.io/
# obi at the pinned tag, generates its eBPF Go bindings, and writes a go.work
# pointing the toolchain at the local checkout. None of these artifacts are
# committed: the OBI tree is multi-MB of generated eBPF C/Go bindings, and
# the workspace file must NOT be in commits or it would mutate the tagged
# tree (goreleaser's dirty-state gate, see ADR-0020 "Build pipeline"). CI
# regenerates everything on every Linux job. See tools/local-k8s/README.md.
third_party/obi/
go.work
go.work.sum

# IDE / editor scratch
.idea/
.vscode/
.cursor/
.zed/
*.swp
*.swo
*.bak
*.orig
*~

# OS
.DS_Store
Thumbs.db

# Local env / secrets
.env
.env.local

# Local-only test configs (kept out of OSS repo to avoid accidental key leaks)
prod-conduit.yaml

# Internal planning materials — kept on the contributor's local checkout but
# not published to the OSS repo. Public-facing planning lives in GitHub
# Issues / a project board.
/conduit-agent-plan/
