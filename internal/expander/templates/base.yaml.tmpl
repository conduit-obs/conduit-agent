{{/*
Conduit V0 base template: minimal OTel Collector configuration produced from
a validated *config.AgentConfig. See internal/expander/expander.go for the
caller and internal/config/types.go for the input shape.

The output of this template is fed verbatim into the embedded upstream OTel
Collector. Anything written here must be valid for the pinned upstream
version in builder-config.yaml. When you add a profile, do it as a fragment
under internal/profiles/<goos>/ and let the expander splice it via
.ExtraReceivers — keep this file the irreducible core that Conduit always
sets.
*/ -}}
# Generated by conduit. Do not edit by hand; edit conduit.yaml or
# internal/expander/templates/base.yaml.tmpl instead.
receivers:
  otlp:
    protocols:
      grpc:
        endpoint: {{ .OTLPBindAddress }}:4317
      http:
        endpoint: {{ .OTLPBindAddress }}:4318
{{- with .ExtraReceivers }}
{{ . -}}
{{- end }}

processors:
  memory_limiter:
    check_interval: 1s
    limit_percentage: 80
    spike_limit_percentage: 25
  # resourcedetection populates host identity (host.name, host.id,
  # host.arch, os.type, os.description, ...) on every emitted signal so
  # multi-host deployments can break down telemetry by host. Always on;
  # not gated by profile since host identity is universal.
  #
  # Detector order matters: with override=false the first detector to set
  # a key wins. [env, system] means OTEL_RESOURCE_ATTRIBUTES (e.g.
  # host.name=node-foo from a Kubernetes downward-API env var) takes
  # precedence over the OS-detected hostname, while system fills in
  # everything env didn't supply. Both detectors leave incoming OTLP
  # resource attributes from upstream apps untouched.
  resourcedetection:
    detectors: [env, system]
    timeout: 2s
    override: false
  batch:
    send_batch_size: 8192
    timeout: 200ms
  resource:
    attributes:
      - key: service.name
        value: {{ .ServiceName | q }}
        action: upsert
      - key: deployment.environment
        value: {{ .DeploymentEnvironment | q }}
        action: upsert
{{- if .K8sAttributes }}
  # k8sattributes enriches every signal with Kubernetes workload metadata
  # by associating the source pod (via IP, UID, or connection) and copying
  # configured fields onto resource attributes. Runs after resourcedetection
  # (so host identity is already on the record) and before resource (so the
  # user's explicit conduit.yaml service.name / deployment.environment can
  # still override what was discovered).
  #
  # filter.node_from_env_var scopes the watcher to pods on the local node
  # (K8S_NODE_NAME comes from the downward API; the Helm chart's DaemonSet
  # wires it into every Conduit pod). Without this scope every Conduit
  # replica would watch every pod in the cluster, dragging on the API
  # server proportional to fleet size.
  k8sattributes:
    auth_type: serviceAccount
    passthrough: false
    filter:
      node_from_env_var: K8S_NODE_NAME
    extract:
      metadata:
        - k8s.namespace.name
        - k8s.pod.name
        - k8s.pod.uid
        - k8s.pod.start_time
        - k8s.deployment.name
        - k8s.replicaset.name
        - k8s.daemonset.name
        - k8s.statefulset.name
        - k8s.job.name
        - k8s.cronjob.name
        - k8s.node.name
    pod_association:
      - sources:
          - from: resource_attribute
            name: k8s.pod.ip
      - sources:
          - from: resource_attribute
            name: k8s.pod.uid
      - sources:
          - from: connection
{{- end }}
  # transform/logs does three things, in three independent statement
  # blocks (run in declaration order; each block's `where` predicate
  # filters records independently):
  #
  #   1. (M9.B) Masks well-known secret patterns in body and
  #      attributes["message"] BEFORE downstream processing copies them
  #      into normalized_message. Default-on per ADR-0006's spirit and
  #      [01-product-requirements.md] §FR-9 — even a Conduit operator who
  #      hasn't read the redaction docs should not accidentally ship
  #      plaintext credentials to Honeycomb / Datadog / Grafana Cloud.
  #      Patterns are intentionally narrow (high-confidence prefix +
  #      length + structure) to avoid false positives that would mask
  #      legitimate hex strings or base64 payloads. Operators who need
  #      stricter masking layer additional rules via overrides:
  #      (ADR-0012); operators who need looser masking are typically
  #      better off fixing their app's logging.
  #
  #   2. Computes a normalized_message attribute alongside the (now
  #      redacted) message so Honeycomb can group similar log lines by
  #      template — masking the high-cardinality bits (PIDs, IDs, UUIDs,
  #      IPs, key=value values) that would otherwise make every line
  #      unique. body is intentionally left untouched here. Only runs
  #      when filelog's default parser populated attributes["message"]
  #      (BSD or ISO syslog lines); OTLP logs from upstream apps and
  #      journald entries pass through unmodified.
  #
  #   3. Defaults severity to INFO when no upstream stage set one.
  #      Filelog parses raw syslog lines and leaves severity_number=0
  #      (UNSPECIFIED), which makes Honeycomb severity filters drop
  #      those records. journald maps PRIORITY -> severity, and OTLP
  #      logs from apps already carry severity, so the
  #      where severity_number == SEVERITY_NUMBER_UNSPECIFIED guard
  #      keeps us from overwriting either.
  transform/logs:
    log_statements:
      - context: log
        conditions:
          - 'IsString(body) or attributes["message"] != nil'
        statements:
          # AWS access key IDs ("AKIA"+16 uppercase alphanumerics) are
          # the most distinctive credential pattern in cloud workloads
          # — the matching 40-char secret access key is too generic
          # for safe regex matching, so masking the access key id is
          # the practical signal that "an AWS credential leaked here".
          - 'replace_pattern(body, "AKIA[0-9A-Z]{16}", "AKIA****REDACTED****") where IsString(body)'
          - 'replace_pattern(attributes["message"], "AKIA[0-9A-Z]{16}", "AKIA****REDACTED****") where attributes["message"] != nil'
          # JSON Web Tokens — three base64url-encoded segments separated
          # by dots, prefixed with the standard "eyJ" header. Distinctive
          # enough to mask without false positives because the prefix
          # plus three-segment structure plus minimum lengths are very
          # unlikely to collide with non-JWT content.
          - 'replace_pattern(body, "eyJ[A-Za-z0-9_=-]{8,}\\.[A-Za-z0-9_=-]{4,}\\.[A-Za-z0-9_=.+/-]{4,}", "eyJ****REDACTED****") where IsString(body)'
          - 'replace_pattern(attributes["message"], "eyJ[A-Za-z0-9_=-]{8,}\\.[A-Za-z0-9_=-]{4,}\\.[A-Za-z0-9_=.+/-]{4,}", "eyJ****REDACTED****") where attributes["message"] != nil'
          # Common credential key=value patterns. Case-insensitive on the
          # key name, terminated by whitespace / comma / semicolon /
          # ampersand / quote so URL-style and form-style encodings both
          # mask cleanly. The value (everything after the =) is replaced
          # with "****REDACTED****"; the key is preserved so operators
          # can still see WHAT was redacted at query time.
          - 'replace_pattern(body, "(?i)(password|passwd|secret|token|apikey|api_key|access_key|aws_secret_access_key|authorization)=[^\\s,&;\"]+", "$1=****REDACTED****") where IsString(body)'
          - 'replace_pattern(attributes["message"], "(?i)(password|passwd|secret|token|apikey|api_key|access_key|aws_secret_access_key|authorization)=[^\\s,&;\"]+", "$1=****REDACTED****") where attributes["message"] != nil'
      - context: log
        conditions:
          - 'attributes["message"] != nil'
        statements:
          - 'set(attributes["normalized_message"], attributes["message"])'
          - 'replace_pattern(attributes["normalized_message"], "[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}", "*")'
          - 'replace_pattern(attributes["normalized_message"], "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b", "*.*.*.*")'
          - 'replace_pattern(attributes["normalized_message"], "(\\w+)=[^\\s,]+", "$1=*")'
          - 'replace_pattern(attributes["normalized_message"], "\\b\\d{4,}\\b", "*")'
      - context: log
        conditions:
          - 'severity_number == SEVERITY_NUMBER_UNSPECIFIED'
        statements:
          - 'set(severity_text, "INFO")'
          - 'set(severity_number, SEVERITY_NUMBER_INFO)'

exporters:
{{- if eq .Output.Mode "honeycomb" }}
  otlphttp/honeycomb:
    endpoint: {{ .Output.Honeycomb.Endpoint | q }}
    headers:
      x-honeycomb-team: {{ .Output.Honeycomb.APIKey | q }}
    compression: gzip
{{- else if eq .Output.Mode "otlp" }}
  otlphttp/otlp:
    endpoint: {{ .Output.OTLP.Endpoint | q }}
{{- if .Output.OTLP.Headers }}
    headers:
{{- range $k, $v := .Output.OTLP.Headers }}
      {{ $k }}: {{ $v | q }}
{{- end }}
{{- end }}
    compression: {{ if .Output.OTLP.Compression }}{{ .Output.OTLP.Compression | q }}{{ else }}gzip{{ end }}
{{- if .Output.OTLP.Insecure }}
    tls:
      insecure: true
{{- end }}
{{- else if eq .Output.Mode "gateway" }}
  otlp/gateway:
    endpoint: {{ .Output.Gateway.Endpoint | q }}
{{- if .Output.Gateway.Headers }}
    headers:
{{- range $k, $v := .Output.Gateway.Headers }}
      {{ $k }}: {{ $v | q }}
{{- end }}
{{- end }}
{{- end }}
  debug:
    verbosity: basic
{{- if .REDEnabled }}

# span_metrics tees the traces pipeline into a derived RED metrics
# stream (request count / error count / duration histogram) that lands
# on the metrics pipeline before any sampling step. The dimension list
# below is the documented Conduit default plus any user-supplied
# additions in metrics.red.span_dimensions /
# metrics.red.extra_resource_dimensions; ADR-0006 documents the
# allowlist + denylist model and conduit doctor (M11) surfaces
# CDT0501 / CDT0510 when those guardrails fire.
#
# aggregation_cardinality_limit caps total tracked dimension
# combinations; excess flows to a single overflow series tagged
# otel.metric.overflow="true" so cardinality-blowup is visible at
# query time instead of crashing the agent.
connectors:
  span_metrics:
    histogram:
      explicit:
        buckets: [{{ join .REDHistogramBuckets ", " }}]
    dimensions:
{{- range .REDSpanDimensions }}
      - name: {{ . }}
{{- end }}
    resource_metrics_key_attributes:
{{- range .REDResourceDimensions }}
      - {{ . }}
{{- end }}
    add_resource_attributes: true
    aggregation_cardinality_limit: {{ .REDCardinalityLimit }}
    metrics_flush_interval: 60s
{{- end }}

# health_check is always on so Docker HEALTHCHECK, k8s liveness/readiness
# probes, and `conduit doctor` (M11) all have a single, vendor-neutral
# endpoint to hit. Bound to 0.0.0.0 on every profile because the endpoint
# only reports collector liveness — there is no telemetry payload to
# protect, and host-mode operators can still reach it via 127.0.0.1.
extensions:
  health_check:
    endpoint: 0.0.0.0:13133

service:
  extensions: [health_check]
  pipelines:
    traces:
      receivers:
{{- range .TraceReceivers }}
        - {{ . }}
{{- end }}
      processors: [{{ join .TraceProcessors ", " }}]
      exporters: [{{ join .TraceExporters ", " }}]
    metrics:
      receivers:
{{- range .MetricReceivers }}
        - {{ . }}
{{- end }}
      processors: [{{ join .MetricProcessors ", " }}]
      exporters: [{{ join .MetricExporters ", " }}]
    logs:
      receivers:
{{- range .LogReceivers }}
        - {{ . }}
{{- end }}
      processors: [{{ join .LogProcessors ", " }}]
      exporters: [{{ join .LogExporters ", " }}]
